<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Secret Birthday 🎂</title>
  <link rel="stylesheet" href="">
</head>

<body style="text-align:center; background:#111; color:white; font-family:Arial;">

  <h2>🔐 Enter Password</h2>
  <input type="password" id="password" placeholder="khusheadii">
  <button onclick="checkPassword()">Unlock</button>

  <div id="content" style="display:none; margin-top:50px;">
    <h1>Happy Birthday 🎉</h1>
    <p>Tumhari life hamesha happy rahe 💖</p>
  </div>

  <!-- JS file link -->
  <script src="script.js"></script>

</body>
</html>
function checkPassword() {
  const correctPassword = "khusheadii"; // apna password
  const input = document.getElementById("password").value;

  if (input === correctPassword) {
    window.location.href = "birthday.html"; // 👉 next page open
  } else {
    alert("Wrong Password ❌");
  }
}
