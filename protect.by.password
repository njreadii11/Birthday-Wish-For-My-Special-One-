<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Secret Birthday 🎂</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      text-align: center;
      background: linear-gradient(135deg, #1a1a1a, #000);
      color: white;
    }

    .box {
      margin-top: 100px;
    }

    input {
      padding: 12px;
      font-size: 16px;
      border-radius: 10px;
      border: none;
      outline: none;
    }

    button {
      padding: 12px 20px;
      font-size: 16px;
      margin-left: 10px;
      border-radius: 10px;
      border: none;
      background: #ff4d6d;
      color: white;
      cursor: pointer;
    }

    #content {
      display: none;
      margin-top: 80px;
      animation: fadeIn 2s ease;
    }

    h1 {
      font-size: 40px;
      color: #ff4d6d;
    }

    p {
      font-size: 20px;
      max-width: 600px;
      margin: auto;
    }

    @keyframes fadeIn {
      from {opacity: 0;}
      to {opacity: 1;}
    }
  </style>

</head>
<body>

  <div class="box">
    <h2>🔐 Enter Password</h2>
    <input type="password" id="password" placeholder="Eadii@74298">
    <button onclick="checkPassword()">Unlock</button>
  </div>

  <div id="content">
    <h1>Happy Birthday 🎉</h1>
    <p>
      Shayad hum ab saath nahi hain...  
      lekin tumhari khushi aaj bhi matter karti hai 💖  
      Happy Birthday... stay happy always ✨
    </p>
  </div>

  <script>
    function checkPassword() {
      const correctPassword = "Eadii@74298"; // 👉 yahan apna password change karo
      const input = document.getElementById("Eadii@74298").value;

      if (input === correctPassword) {
        document.querySelector(".box").style.display = "none";
        document.getElementById("content").style.display = "block";
      } else {
        alert("Wrong Password ❌");
      }
    }
  </script>

</body>
</html>
